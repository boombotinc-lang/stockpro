# ============================================================
# apps/app — Environment Variables
# Copy to .env.local and fill in values
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Supabase PostgreSQL)
DATABASE_URL=           # pooled connection string (pgbouncer)
DIRECT_URL=             # direct connection (used by Prisma migrations)

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# App Config
NEXT_PUBLIC_APP_URL=https://app.stockpro.com.br
NEXT_PUBLIC_APP_NAME=StockPro

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@stockpro.com.br

# Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
