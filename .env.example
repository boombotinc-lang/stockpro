# ============================================================
# .env.local — copie este arquivo e preencha os valores
# NUNCA commite o .env.local no git
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...    # apenas no servidor, nunca no cliente

# --- Banco de dados (Supabase Postgres) ---
# Transaction pooler (para queries normais via Prisma)
DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection (para migrations Prisma)
DIRECT_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# IDs dos preços (criar no Stripe Dashboard > Products)
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="StockPro"

# --- Email (Resend) ---
RESEND_API_KEY=re_...
EMAIL_FROM="StockPro <noreply@seudominio.com.br>"

# --- Upstash Redis (rate limiting) ---
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...
